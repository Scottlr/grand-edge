{
  "$defs": {
    "GraphArtifactMetadata": {
      "properties": {
        "edge_observation_window_end": {
          "format": "date-time",
          "type": "string"
        },
        "edge_observation_window_start": {
          "format": "date-time",
          "type": "string"
        },
        "graph_feature_groups": {
          "items": {
            "$ref": "#/$defs/GraphFeatureGroup"
          },
          "type": "array"
        },
        "graph_feature_set_version": {
          "type": "string"
        },
        "graph_version": {
          "type": "string"
        },
        "relation_corpus_hash": {
          "type": "string"
        }
      },
      "required": [
        "graph_feature_set_version",
        "graph_version",
        "relation_corpus_hash",
        "edge_observation_window_start",
        "edge_observation_window_end",
        "graph_feature_groups"
      ],
      "title": "GraphArtifactMetadata",
      "type": "object"
    },
    "GraphFeatureGroup": {
      "enum": [
        "own_item_features",
        "observed_execution_proxy_features",
        "neighbor_return_features",
        "sector_features",
        "conversion_features",
        "shock_features",
        "edge_stability_features",
        "event_features",
        "missing_data_flags"
      ],
      "type": "string"
    },
    "TrainingTargetLabel": {
      "enum": [
        "future_return_6h",
        "future_tax_adjusted_return_6h",
        "future_actionable_return_6h"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "evaluation_window_end": {
      "format": "date-time",
      "type": "string"
    },
    "evaluation_window_start": {
      "format": "date-time",
      "type": "string"
    },
    "feature_schema_hash": {
      "type": "string"
    },
    "feature_set_version": {
      "type": "string"
    },
    "graph": {
      "anyOf": [
        {
          "$ref": "#/$defs/GraphArtifactMetadata"
        },
        {
          "type": "null"
        }
      ]
    },
    "known_limitations": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "metrics": {
      "additionalProperties": true,
      "type": "object"
    },
    "model_version": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "strategy_id": {
      "type": "string"
    },
    "target_label": {
      "$ref": "#/$defs/TrainingTargetLabel"
    },
    "training_window_end": {
      "format": "date-time",
      "type": "string"
    },
    "training_window_start": {
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "strategy_id",
    "model_version",
    "feature_set_version",
    "feature_schema_hash",
    "training_window_start",
    "training_window_end",
    "evaluation_window_start",
    "evaluation_window_end",
    "metrics",
    "known_limitations",
    "target_label",
    "notes"
  ],
  "title": "ModelCardDocument",
  "type": "object"
}
