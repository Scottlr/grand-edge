{
  "$defs": {
    "GraphFeatureGroup": {
      "enum": [
        "own_item_features",
        "observed_execution_proxy_features",
        "neighbor_return_features",
        "sector_features",
        "conversion_features",
        "shock_features",
        "edge_stability_features",
        "event_features",
        "missing_data_flags"
      ],
      "type": "string"
    },
    "TrainingTargetLabel": {
      "enum": [
        "future_return_6h",
        "future_tax_adjusted_return_6h",
        "future_actionable_return_6h"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "feature_names": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "feature_schema_hash": {
      "type": "string"
    },
    "feature_set_version": {
      "type": "string"
    },
    "graph_feature_groups": {
      "items": {
        "$ref": "#/$defs/GraphFeatureGroup"
      },
      "type": "array"
    },
    "target_label": {
      "$ref": "#/$defs/TrainingTargetLabel"
    }
  },
  "required": [
    "feature_set_version",
    "feature_names",
    "target_label",
    "feature_schema_hash"
  ],
  "title": "ArtifactFeatureSchemaDocument",
  "type": "object"
}
