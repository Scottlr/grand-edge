# Postgres connection used by local Rust services and development tools.
DATABASE_URL=postgres://grand_edge:grand_edge@localhost:5432/grand_edge

# Required for all future OSRS Wiki requests; keep GrandEdge name and contact.
GRAND_EDGE_USER_AGENT=GrandEdge/0.1 (OSRS Grand Exchange recommendation terminal; contact: scott.rangeley@outlook.com)

# OSRS Wiki price API base URL.
OSRS_WIKI_BASE_URL=https://prices.runescape.wiki/api/v1/osrs

# Planned default ingest cadence in seconds.
INGEST_POLL_SECONDS=300

# Frontend base URL for the local backend API.
VITE_API_BASE_URL=http://localhost:3000
